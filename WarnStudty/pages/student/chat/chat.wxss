.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f4f6f8;
}

.status-bar {
  background: #ffffff;
}

.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx 18rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e6ebf0;
}

.nav-left,
.nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 40rpx;
  color: #1a1a1a;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

.agent-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 22rpx;
  background: #fff;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(16, 24, 40, 0.06);
}

.nav-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.agent-meta {
  display: flex;
  flex-direction: column;
}

.agent-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.emotion-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.emotion-icon {
  font-size: 20rpx;
}

.emotion-label {
  font-size: 21rpx;
  color: #6b7280;
}

.message-list {
  flex: 1;
  padding: 24rpx 24rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.time-divider {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.time-text {
  font-size: 22rpx;
  color: #6b7280;
  background: #e9edf2;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.message-wrapper {
  margin-bottom: 24rpx;
  display: flex;
}

.message-wrapper.ai {
  justify-content: flex-start;
}

.message-wrapper.user {
  justify-content: flex-end;
}

.message-content {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  max-width: 80%;
}

.msg-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.bubble-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bubble {
  padding: 22rpx 26rpx;
  border-radius: 18rpx;
  position: relative;
  word-break: break-all;
}

.ai-bubble {
  background: #fff;
  border-top-left-radius: 8rpx;
  box-shadow: 0 6rpx 14rpx rgba(15, 23, 42, 0.06);
}

.user-bubble {
  background: #e6ebf2;
  border-top-right-radius: 8rpx;
}

.bubble-text {
  font-size: 31rpx;
  line-height: 1.65;
  color: #1f2937;
}

.msg-meta {
  display: flex;
  align-items: center;
}

.emotion-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.loading-message {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.loading-bubble {
  padding: 24rpx 32rpx;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.typing-indicator .dot {
  width: 12rpx;
  height: 12rpx;
  background: #b3b3b3;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-indicator .dot:nth-child(1) {
  animation-delay: 0s;
}
.typing-indicator .dot:nth-child(2) {
  animation-delay: 0.2s;
}
.typing-indicator .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%,
  60%,
  100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-8rpx);
    opacity: 1;
  }
}

.stop-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  border: 2rpx solid #ef4444;
  margin-left: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.stop-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
}

.scroll-placeholder {
  flex-shrink: 0;
}

.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid #e6ebf0;
  padding: 8rpx 16rpx;
  padding-bottom: calc(4rpx + env(safe-area-inset-bottom));
  transition: bottom 0.2s ease;
}

.edit-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: #f4f7fb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.edit-hint {
  font-size: 24rpx;
  color: #0f766e;
}

.edit-cancel {
  font-size: 24rpx;
  color: #0ea5a4;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.input-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 32rpx;
  background: #f1f5f9;
  border: 1rpx solid #dbe3ec;
}

.mode-icon {
  display: block;
  font-size: 28rpx;
  color: #0f766e;
  font-weight: 600;
  line-height: 1;
}

.voice-icon-image {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
}

.voice-icon-text {
  display: none;
}

.voice-signal-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  transform: rotate(90deg);
}

.signal-dot {
  position: absolute;
  left: 4rpx;
  top: 50%;
  width: 6rpx;
  height: 6rpx;
  margin-top: -3rpx;
  border-radius: 50%;
  background: #0f766e;
}

.signal-arc {
  position: absolute;
  top: 50%;
  border: 2rpx solid #0f766e;
  border-left: none;
  border-radius: 0 999rpx 999rpx 0;
  transform: translateY(-50%);
}

.arc-1 {
  left: 10rpx;
  width: 8rpx;
  height: 10rpx;
}

.arc-2 {
  left: 14rpx;
  width: 12rpx;
  height: 16rpx;
}

.arc-3 {
  left: 18rpx;
  width: 14rpx;
  height: 22rpx;
}

.plus-btn {
  padding: 0;
}

.plus-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #f1f5f9;
  border: 1rpx solid #dbe3ec;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 30rpx;
  color: #0f766e;
  font-weight: 500;
  line-height: 1;
}

.input-wrapper {
  flex: 1;
  background: #fff;
  border-radius: 18rpx;
  border: 1rpx solid #d1d9e3;
  min-height: 64rpx;
  max-height: 180rpx;
  overflow: hidden;
}

.chat-input {
  width: 100%;
  padding: 10rpx 18rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #111827;
  min-height: 64rpx;
  max-height: 180rpx;
}

.input-placeholder {
  color: #b3b3b3;
}

.send-btn {
  width: 90rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf1f6;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.send-btn.active {
  background: #0f766e;
}

.send-text {
  font-size: 25rpx;
  color: #b3b3b3;
}

.send-btn.active .send-text {
  color: #fff;
  font-weight: 500;
}

.voice-row {
  justify-content: center;
}

.voice-input-btn {
  flex: 1;
  height: 76rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d1d9e3;
}

.voice-input-btn.recording {
  background: #0f766e;
  border-color: #0f766e;
}

.voice-btn-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.voice-input-btn.recording .voice-btn-text {
  color: #fff;
}

.context-menu {
  position: fixed;
  z-index: 1000;
  transform: translateX(-50%);
}

.context-menu.show {
  display: block;
}

.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.menu-content {
  display: flex;
  gap: 8rpx;
  background: #1f2937;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
}

.menu-icon {
  font-size: 24rpx;
  color: #e5e7eb;
  font-weight: 600;
}

.menu-label {
  font-size: 20rpx;
  color: #fff;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 500;
  display: none;
}

.modal-overlay.show {
  display: block;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.toolbox-panel,
.session-panel,
.settings-panel,
.avatar-panel,
.context-panel,
.info-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.toolbox-header,
.session-header,
.settings-header,
.avatar-header,
.context-header,
.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.toolbox-title,
.session-title,
.settings-title,
.avatar-title,
.context-title,
.info-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.toolbox-close,
.settings-close,
.avatar-close,
.context-close,
.info-close {
  font-size: 48rpx;
  color: #b3b3b3;
  line-height: 1;
}

.quick-questions {
  padding: 24rpx 36rpx 0;
}

.quick-title {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.question-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.question-item {
  padding: 12rpx 20rpx;
  background: #f1f5f9;
  border-radius: 20rpx;
}

.question-item text {
  font-size: 24rpx;
  color: #0f766e;
}

.toolbox-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 24rpx 36rpx 32rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.tool-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}

.tool-icon-context,
.tool-icon-settings,
.tool-icon-session,
.tool-icon-clear {
  background: #f1f5f9;
}

.tool-emoji {
  font-size: 34rpx;
  color: #0f766e;
  font-weight: 600;
}

.tool-name {
  font-size: 24rpx;
  color: #333;
}

.session-new-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #0f766e;
  border-radius: 24rpx;
}

.new-icon {
  font-size: 28rpx;
  color: #fff;
}

.new-text {
  font-size: 24rpx;
  color: #fff;
}

.session-list {
  max-height: 50vh;
  padding: 16rpx 0;
}

.session-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.session-item.active {
  background: #ecfdf5;
}

.session-info {
  flex: 1;
  overflow: hidden;
}

.session-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-preview {
  display: block;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  margin-left: 16rpx;
}

.session-time {
  font-size: 22rpx;
  color: #b3b3b3;
}

.session-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.delete-icon {
  font-size: 32rpx;
  color: #999;
}

.empty-session {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.settings-section {
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.avatar-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.current-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-info {
  flex: 1;
}

.avatar-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.avatar-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.picker-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.emotion-slider {
  padding: 0 8rpx;
}

.slider {
  width: 100%;
}

.emotion-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.label-item {
  font-size: 22rpx;
  color: #999;
}

.current-emotion {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

.emotion-display {
  font-size: 28rpx;
  font-weight: 500;
}

.about-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.about-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.about-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.avatar-list {
  padding: 16rpx 36rpx 32rpx;
}

.avatar-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.avatar-option:last-child {
  margin-bottom: 0;
}

.option-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.option-info {
  flex: 1;
}

.option-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #0f766e;
  border-radius: 50%;
}

.check-icon {
  font-size: 28rpx;
  color: #fff;
}

.context-scroll {
  max-height: 50vh;
  padding: 24rpx 36rpx;
}

.context-summary {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #ecfdf5;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #666;
}

.summary-count {
  font-size: 26rpx;
  color: #0f766e;
  font-weight: 600;
}

.context-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.context-item {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.context-role {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.context-role.ai {
  background: #ecfdf5;
}

.context-role.user {
  background: #e2e8f0;
}

.role-text {
  font-size: 22rpx;
  font-weight: 500;
}

.context-role.ai .role-text {
  color: #0f766e;
}

.context-role.user .role-text {
  color: #1f2937;
}

.context-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.info-body {
  padding: 24rpx 36rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.info-intro {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 32rpx;
  white-space: pre-wrap;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e5e5e5;
  box-sizing: border-box;
  min-height: 80rpx;
}

.form-input:focus {
  border-color: #0f766e;
  background: #fff;
}

.gender-options {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  text-align: center;
  background: #f8f8f8;
}

.gender-option text {
  font-size: 28rpx;
  color: #666;
}

.gender-option.active {
  border-color: #0f766e;
  background: #e8f5e9;
}

.gender-option.active text {
  color: #0f766e;
  font-weight: 600;
}

.info-footer {
  padding: 0 36rpx 32rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: #0f766e;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}
