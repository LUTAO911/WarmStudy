<!-- knowledge.wxml - 心理知识库 -->

<view class="container">
  <!-- 分类导航 -->
  <scroll-view scroll-x class="category-scroll">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-item {{selectedCategory === item ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- 知识列表 -->
  <scroll-view scroll-y class="knowledge-list" wx:if="{{!loading}}">
    <view
      wx:for="{{filteredList}}"
      wx:key="id"
      class="knowledge-card"
      bindtap="onKnowledgeTap"
      data-item="{{item}}"
    >
      <view class="card-header">
        <view class="category-tag">{{item.category}}</view>
      </view>
      <view class="card-title">{{item.title}}</view>
      <view class="card-content">{{item.content}}</view>
      <view class="card-footer">
        <view class="keywords">
          <text wx:for="{{item.keywords}}" wx:for-item="kw" wx:key="*this" class="keyword-tag">{{kw}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{filteredList.length === 0}}" class="empty-state">
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无相关知识</text>
    </view>
  </scroll-view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>

<!-- 知识详情弹窗 -->
<view wx:if="{{showDetail}}" class="detail-modal" bindtap="closeDetail">
  <view class="detail-content" catchtap=" ">
    <view class="detail-header">
      <view class="detail-category">{{selectedItem.category}}</view>
      <view class="close-btn" bindtap="closeDetail">×</view>
    </view>
    <view class="detail-title">{{selectedItem.title}}</view>
    <scroll-view scroll-y class="detail-body">
      <text class="detail-text">{{selectedItem.content}}</text>
      <view class="detail-keywords">
        <text class="kw-label">相关关键词：</text>
        <text wx:for="{{selectedItem.keywords}}" wx:for-item="kw" wx:key="*this" class="keyword-tag">{{kw}}</text>
      </view>
    </scroll-view>
  </view>
</view>
