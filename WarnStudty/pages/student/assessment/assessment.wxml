<view class="page">
  <!-- ===== 专业头部 ===== -->
  <view class="page-header">
    <view class="header-top">
      <view class="header-title-group">
        <text class="header-title">心测站</text>
        <text class="header-sub">专业心理追踪</text>
      </view>
      <view class="header-date">{{today}}</view>
    </view>
    <!-- 打卡总进度 -->
    <view class="checkin-progress-bar">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{checkinPercent}}%"></view>
      </view>
      <text class="progress-label">{{checkinDone ? '今日打卡完成' : '今日打卡 ' + checkinCount + '/4'}}</text>
    </view>
  </view>

  <!-- ===== 今日打卡 四维追踪 ===== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">今日打卡</text>
    </view>
    <view class="checkin-grid">
      <view class="checkin-item {{checkin.emotion ? 'done' : ''}}" bindtap="onCheckin" data-type="emotion">
        <view class="checkin-inner">
          <image class="checkin-icon" src="/images/ui-emotion.png" mode="aspectFit" />
          <text class="checkin-label">情绪</text>
          <text class="checkin-value">{{checkin.emotion || '未打卡'}}</text>
        </view>
        <view class="checkin-status-dot {{checkin.emotion ? 'on' : ''}}"></view>
      </view>
      <view class="checkin-item {{checkin.sleep ? 'done' : ''}}" bindtap="onCheckin" data-type="sleep">
        <view class="checkin-inner">
          <image class="checkin-icon" src="/images/ui-sleep.png" mode="aspectFit" />
          <text class="checkin-label">睡眠</text>
          <text class="checkin-value">{{checkin.sleep || '未打卡'}}</text>
        </view>
        <view class="checkin-status-dot {{checkin.sleep ? 'on' : ''}}"></view>
      </view>
      <view class="checkin-item {{checkin.study ? 'done' : ''}}" bindtap="onCheckin" data-type="study">
        <view class="checkin-inner">
          <image class="checkin-icon" src="/images/ui-study.png" mode="aspectFit" />
          <text class="checkin-label">学习</text>
          <text class="checkin-value">{{checkin.study || '未打卡'}}</text>
        </view>
        <view class="checkin-status-dot {{checkin.study ? 'on' : ''}}"></view>
      </view>
      <view class="checkin-item {{checkin.social ? 'done' : ''}}" bindtap="onCheckin" data-type="social">
        <view class="checkin-inner">
          <image class="checkin-icon" src="/images/ui-social.png" mode="aspectFit" />
          <text class="checkin-label">社交</text>
          <text class="checkin-value">{{checkin.social || '未打卡'}}</text>
        </view>
        <view class="checkin-status-dot {{checkin.social ? 'on' : ''}}"></view>
      </view>
    </view>
    <view class="checkin-tip" wx:if="{{checkinDone}}">
      <text class="tip-icon">提</text>
      <text class="tip-text">今日打卡完成！建议去「AI心理师」查看个性化建议</text>
    </view>
  </view>

  <!-- ===== 心理测评 ===== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">心理测评</text>
      <view class="header-tag">专业量表</view>
    </view>
    <view class="test-list">
      <view class="test-item" bindtap="onStartTest" data-type="weekly">
        <view class="test-icon-wrap">
          <text class="test-icon-text">综</text>
        </view>
        <view class="test-info">
          <text class="test-name">心理健康综合评估</text>
          <text class="test-meta">MHT量表改编 · 8道题 · 约3分钟</text>
          <text class="test-source">来源：华东师范大学MHT标准化量表</text>
        </view>
        <view class="test-status {{testStatus.weekly ? 'done' : 'pending'}}">
          {{testStatus.weekly ? '已完成' : '未完成'}}
        </view>
      </view>
      <view class="test-item" bindtap="onStartTest" data-type="pressure">
        <view class="test-icon-wrap">
          <text class="test-icon-text">压</text>
        </view>
        <view class="test-info">
          <text class="test-name">感知压力评估</text>
          <text class="test-meta">PSS-10量表改编 · 10道题 · 约2分钟</text>
          <text class="test-source">来源：国际通用PSS压力量表中文版</text>
        </view>
        <view class="test-status {{testStatus.pressure ? 'done' : 'pending'}}">
          {{testStatus.pressure ? '已完成' : '未完成'}}
        </view>
      </view>
      <view class="test-item" bindtap="onStartTest" data-type="communication">
        <view class="test-icon-wrap">
          <text class="test-icon-text">亲</text>
        </view>
        <view class="test-info">
          <text class="test-name">亲子沟通质量评估</text>
          <text class="test-meta">亲子沟通量表改编 · 10道题 · 约2分钟</text>
          <text class="test-source">来源：标准化亲子沟通量表</text>
        </view>
        <view class="test-status {{testStatus.communication ? 'done' : 'pending'}}">
          {{testStatus.communication ? '已完成' : '未完成'}}
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 历史雷达图 ===== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近心理画像</text>
      <text class="section-more" bindtap="onViewFullReport">查看完整报告 ›</text>
    </view>
    <!-- 雷达图：左右布局 -->
    <view class="radar-wrapper" wx:if="{{!showTest}}">
      <!-- 左侧雷达图 -->
      <view class="radar-chart">
        <!-- 四层环形背景 -->
        <view class="radar-ring radar-ring-4"></view>
        <view class="radar-ring radar-ring-3"></view>
        <view class="radar-ring radar-ring-2"></view>
        <view class="radar-ring radar-ring-1"></view>
        <!-- 六条轴线 -->
        <view class="radar-line radar-line-0"></view>
        <view class="radar-line radar-line-1"></view>
        <view class="radar-line radar-line-2"></view>
        <view class="radar-line radar-line-3"></view>
        <view class="radar-line radar-line-4"></view>
        <view class="radar-line radar-line-5"></view>
        <canvas
          canvas-id="radarAreaCanvas"
          class="radar-area-canvas"
          width="{{radarCanvasSize}}"
          height="{{radarCanvasSize}}"
        ></canvas>
        <!-- 数据点 -->
        <view class="radar-dot radar-dot-0" style="{{dot0Style}}"></view>
        <view class="radar-dot radar-dot-1" style="{{dot1Style}}"></view>
        <view class="radar-dot radar-dot-2" style="{{dot2Style}}"></view>
        <view class="radar-dot radar-dot-3" style="{{dot3Style}}"></view>
        <view class="radar-dot radar-dot-4" style="{{dot4Style}}"></view>
        <view class="radar-dot radar-dot-5" style="{{dot5Style}}"></view>
        <!-- 六个轴线标签（紧贴外环外侧） -->
        <text class="radar-lbl radar-lbl-0">学习焦虑</text>
        <text class="radar-lbl radar-lbl-1">对人焦虑</text>
        <text class="radar-lbl radar-lbl-2">孤独倾向</text>
        <text class="radar-lbl radar-lbl-3">自责倾向</text>
        <text class="radar-lbl radar-lbl-4">过敏倾向</text>
        <text class="radar-lbl radar-lbl-5">身体症状</text>
      </view>
      <!-- 右侧指标列表 -->
      <view class="radar-indicators">
        <view class="indicator-item">
          <view class="indicator-dot" style="background:#166534"></view>
          <text class="indicator-label">学习焦虑</text>
          <text class="indicator-score">{{radarScores[0]}}</text>
        </view>
        <view class="indicator-item">
          <view class="indicator-dot" style="background:#1f7a4a"></view>
          <text class="indicator-label">对人焦虑</text>
          <text class="indicator-score">{{radarScores[1]}}</text>
        </view>
        <view class="indicator-item">
          <view class="indicator-dot" style="background:#2a8f61"></view>
          <text class="indicator-label">孤独倾向</text>
          <text class="indicator-score">{{radarScores[2]}}</text>
        </view>
        <view class="indicator-item">
          <view class="indicator-dot" style="background:#35a478"></view>
          <text class="indicator-label">自责倾向</text>
          <text class="indicator-score">{{radarScores[3]}}</text>
        </view>
        <view class="indicator-item">
          <view class="indicator-dot" style="background:#46b690"></view>
          <text class="indicator-label">过敏倾向</text>
          <text class="indicator-score">{{radarScores[4]}}</text>
        </view>
        <view class="indicator-item">
          <view class="indicator-dot" style="background:#5cc6a6"></view>
          <text class="indicator-label">身体症状</text>
          <text class="indicator-score">{{radarScores[5]}}</text>
        </view>
        <view class="indicator-tip">原始分，越低越健康</view>
      </view>
    </view>
    <!-- 风险提示 -->
    <view class="risk-alert {{riskLevel >= 3 ? 'show' : ''}}">
      <image class="risk-icon" src="/images/ui-warning.png" mode="aspectFit" />
      <text class="risk-text">检测到 {{riskLevel}} 项偏高，建议与AI朋朋深入聊聊</text>
    </view>
  </view>

  <!-- ===== 测评弹窗 ===== -->
  <view class="test-modal {{showTest ? 'show' : ''}}" wx:if="{{showTest}}">
    <view class="test-modal-mask" bindtap="onCloseTest"></view>
    <view class="test-modal-content">
      <view class="modal-header">
        <view class="modal-title-group">
          <text class="modal-title">{{currentTest.name}}</text>
          <text class="modal-subtitle">{{currentTest.source}}</text>
        </view>
        <text class="modal-close" bindtap="onCloseTest">×</text>
      </view>
      <!-- 进度条 -->
      <view class="modal-progress-bar">
        <view class="modal-progress-fill" style="width: {{(currentQ + 1) / currentTest.questions.length * 100}}%"></view>
      </view>
      <view class="modal-progress-text">第 {{currentQ + 1}} 题 / 共 {{currentTest.questions.length}} 题</view>
      <!-- 题目 -->
      <view class="modal-body">
        <view class="question-card">
          <text class="question-number">Q{{currentQ + 1}}</text>
          <text class="question-text">{{currentTest.questions[currentQ].text}}</text>
        </view>
        <view class="options">
          <view
            class="option-item {{selectedOption === idx ? 'selected' : ''}}"
            wx:for="{{currentTest.questions[currentQ].options}}"
            wx:for-item="opt"
            wx:for-index="idx"
            wx:key="idx"
            bindtap="onSelectOption"
            data-idx="{{idx}}"
          >
            <view class="option-radio">
              <view class="option-radio-inner {{selectedOption === idx ? 'on' : ''}}"></view>
            </view>
            <text class="option-text">{{opt}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-next {{selectedOption === null ? 'disabled' : ''}}" bindtap="onNextQuestion" disabled="{{selectedOption === null}}">
          {{currentQ < currentTest.questions.length - 1 ? '下一题 ›' : '提交测评'}}
        </button>
      </view>
    </view>
  </view>

  <view style="height:40rpx"></view>
  <tab-bar />
</view>
