/* login.wxss - 统一登录页 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f5f5f5 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* ===== Logo区域 ===== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.logo-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #10b981;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  font-weight: 700;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999;
}

/* ===== 身份选择 ===== */
.role-section {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.role-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.role-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transition: all 0.3s;
}

.role-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.role-card.student {
  border: 2rpx solid #e8f5e9;
}

.role-card.parent {
  border: 2rpx solid #fff3e0;
}

.role-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.role-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  color: #166534;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.role-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.role-arrow {
  position: absolute;
  right: 40rpx;
  font-size: 40rpx;
  font-weight: 300;
}

/* ===== 登录区域 ===== */
.login-section {
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.role-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.role-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.switch-role {
  font-size: 26rpx;
  color: #667eea;
}

/* ===== 登录按钮 ===== */
.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.login-btn::after {
  border: none;
}

.login-btn.wechat {
  background: #07c160;
  color: #fff;
}

.login-btn.phone {
  color: #fff;
  margin-top: 32rpx;
}

.login-btn.phone.student-theme {
  background: #00c853;
}

.login-btn.phone.parent-theme {
  background: #ff9500;
}

.btn-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.btn-text {
  font-size: 30rpx;
}

/* ===== 分割线 ===== */
.divider {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 32rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.divider-text {
  font-size: 24rpx;
  color: #999;
}

/* ===== 手机号输入 ===== */
.phone-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.phone-input-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.phone-prefix {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.phone-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.code-input-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.code-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding: 24rpx 0;
}

.code-btn {
  width: 180rpx;
  height: 64rpx;
  background: #f5f5f5;
  color: #667eea;
  font-size: 24rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.code-btn::after {
  border: none;
}

.code-btn.disabled {
  color: #999;
  background: #f0f0f0;
}

/* ===== 用户协议 ===== */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 40rpx;
  gap: 8rpx;
}

.agree-checkbox {
  transform: scale(0.7);
}

.agree-text {
  font-size: 22rpx;
  color: #999;
}

.agree-link {
  font-size: 22rpx;
  color: #667eea;
}
