/* 家长端设置页 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 160rpx;
}
.account-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.account-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #338b6d, #57a58d);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
}
.account-info {
  flex: 1;
}
.account-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.account-phone {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 4rpx;
}
.account-edit {
  font-size: 28rpx;
  color: #245a48;
  font-weight: 500;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.menu-item {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  margin-right: 12rpx;
}
.success {
  background: #eaf6f1;
  color: #245a48;
}
.warn {
  background: #fff7ed;
  color: #f59e0b;
}
.menu-value {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}
.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}
.logout-btn {
  text-align: center;
  font-size: 30rpx;
  color: #ff3b30;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.parent-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  z-index: 120;
}

.parent-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.parent-tab-icon {
  width: 38rpx;
  height: 38rpx;
}

.parent-tab-text {
  font-size: 22rpx;
  color: #94a3b8;
}

.dialog-icon-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  border: 1rpx solid #9bcfbd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.parent-tab-item.active .parent-tab-text {
  color: #245a48;
}
