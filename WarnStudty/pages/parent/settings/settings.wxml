<view class="page">
  <view class="account-card">
    <view class="account-avatar"><text class="avatar-text">{{avatarText}}</text></view>
    <view class="account-info">
      <text class="account-name">{{accountName}}</text>
      <text class="account-phone">{{accountPhone}}</text>
    </view>
    <view class="account-edit">编辑</view>
  </view>

  <view class="section-title">绑定管理</view>
  <view class="menu-card">
    <view class="menu-item" bindtap="onBindChild">
      <text class="menu-text">孩子账号绑定</text>
      <text class="menu-status {{childBindingClass}}">{{childBindingText}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onBindSchool">
      <text class="menu-text">智学网账号绑定</text>
      <text class="menu-status warn">未绑定</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onBindParent">
      <text class="menu-text">邀请另一位家长</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section-title">提醒设置</view>
  <view class="menu-card">
    <view class="menu-item">
      <text class="menu-text">每日打卡提醒</text>
      <switch checked="{{notif.checkin}}" bindchange="onToggle" data-type="checkin" color="#FF9500"/>
    </view>
    <view class="menu-item">
      <text class="menu-text">周报告推送</text>
      <switch checked="{{notif.weekly}}" bindchange="onToggle" data-type="weekly" color="#FF9500"/>
    </view>
    <view class="menu-item">
      <text class="menu-text">异常预警通知</text>
      <switch checked="{{notif.alert}}" bindchange="onToggle" data-type="alert" color="#FF9500"/>
    </view>
  </view>

  <view class="section-title">关于</view>
  <view class="menu-card">
    <view class="menu-item">
      <text class="menu-text">版本信息</text>
      <text class="menu-value">v1.0.0</text>
    </view>
    <view class="menu-item"><text class="menu-text">用户协议</text><text class="menu-arrow">›</text></view>
    <view class="menu-item"><text class="menu-text">隐私政策</text><text class="menu-arrow">›</text></view>
  </view>

  <view class="logout-btn" bindtap="onLogout">退出登录</view>

  <view class="parent-tabbar">
    <view class="parent-tab-item" bindtap="onParentHome">
      <image class="parent-tab-icon" src="/images/tab-assess.png" mode="aspectFit" />
      <text class="parent-tab-text">孩子</text>
    </view>
    <view class="parent-tab-item" bindtap="onParentAI">
      <view class="dialog-icon-circle">
        <image class="parent-tab-icon" src="/images/tab-dialog.png" mode="aspectFit" />
      </view>
      <text class="parent-tab-text">对话</text>
    </view>
    <view class="parent-tab-item active" bindtap="onParentSettings">
      <image class="parent-tab-icon" src="/images/tab-center-active.png" mode="aspectFit" />
      <text class="parent-tab-text">设置</text>
    </view>
  </view>
</view>
