<view class="page">
  <!-- 报告头部 -->
  <view class="report-header">
    <view class="report-type-row">
      <text class="report-type">{{reportTypeLabel[report.scale_id] || report.scale_id}}</text>
      <text class="report-date">{{report.date}}</text>
    </view>
    <view class="report-score-circle">
      <view class="score-ring">
        <view class="score-inner">
          <text class="score-num">{{report.normalized}}</text>
          <text class="score-denom">/100</text>
        </view>
      </view>
      <view class="score-label-col">
        <view class="level-badge {{levelClass}}">
          {{reportLevelLabel[report.level] || '正常'}}
        </view>
        <text class="level-desc">{{levelDesc}}</text>
      </view>
    </view>
  </view>

  <!-- 综合评价 -->
  <view class="section">
    <view class="section-label">📋 综合评价</view>
    <text class="report-summary">{{report.summary || '暂无评价'}}</text>
  </view>

  <!-- 关键发现 -->
  <view class="section" wx:if="{{report.key_findings && report.key_findings.length > 0}}">
    <view class="section-label">🔍 关键发现</view>
    <view class="finding-item" wx:for="{{report.key_findings}}" wx:key="index">
      <text class="finding-num">{{index + 1}}</text>
      <text class="finding-text">{{item}}</text>
    </view>
  </view>

  <!-- 维度分析 -->
  <view class="section" wx:if="{{report.dimensions && report.dimensions.length > 0}}">
    <view class="section-label">📊 维度分析</view>
    <view class="dim-item" wx:for="{{report.dimensions}}" wx:key="name">
      <view class="dim-header">
        <text class="dim-name">{{item.name}}</text>
        <text class="dim-score {{item.level}}">{{item.score}}/{{item.max}}</text>
      </view>
      <view class="dim-bar-bg">
        <view class="dim-bar-fill {{item.level}}" style="width:{{item.pct}}%"></view>
      </view>
      <text class="dim-desc">{{item.level_label}}</text>
    </view>
  </view>

  <!-- AI建议 -->
  <view class="section" wx:if="{{report.advice}}">
    <view class="section-label ai-label">💡 针对孩子的建议</view>
    <view class="advice-card">
      <text class="advice-text">{{report.advice}}</text>
    </view>
  </view>

  <!-- 家长建议 -->
  <view class="section" wx:if="{{report.parent_advice}}">
    <view class="section-label parent-label">👨‍👩‍👧 给家长的建议</view>
    <view class="advice-card parent-card">
      <text class="advice-text">{{report.parent_advice}}</text>
    </view>
  </view>

  <!-- 风险提示 -->
  <view class="risk-card {{riskClass}}" wx:if="{{report.level === 'severe' || report.level === 'concerning'}}">
    <text class="risk-icon">⚠️</text>
    <view class="risk-content">
      <text class="risk-title">需要注意</text>
      <text class="risk-desc">{{report.level === 'severe' ? '检测到严重心理指标，建议尽快寻求专业心理医生帮助' : '部分指标偏高，建议密切关注并与孩子保持沟通'}}</text>
    </view>
  </view>

  <view style="height:40rpx"></view>
</view>
