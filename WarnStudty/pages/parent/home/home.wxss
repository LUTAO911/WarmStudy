/* home.wxss - 家长端首页 */
.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.parent-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  z-index: 120;
}

.parent-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.parent-tab-icon {
  width: 38rpx;
  height: 38rpx;
}

.parent-tab-text {
  font-size: 22rpx;
  color: #94a3b8;
}

.dialog-icon-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  border: 1rpx solid #9bcfbd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.parent-tab-item.active .parent-tab-text {
  color: #336d5a;
}

/* ===== 头部 ===== */
.page-header {
  background: linear-gradient(135deg, #338b6d 0%, #57a58d 100%);
  padding: 48rpx 32rpx 28rpx;
  color: #fff;
  border-radius: 0 0 32rpx 32rpx;
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}
.header-child-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.child-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.child-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}
.online-dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 16rpx;
  height: 16rpx;
  background: #4cd964;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.8);
}
.child-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.child-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
.child-meta {
  font-size: 22rpx;
  opacity: 0.8;
}
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.header-date {
  font-size: 26rpx;
  opacity: 0.85;
}
.bind-btn {
  background: rgba(255, 255, 255, 0.25);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  color: #fff;
}

.empty-bind-card {
  margin: 24rpx;
  background: #ffffff;
  border: 1rpx solid #d1fae5;
  border-radius: 20rpx;
  padding: 34rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-bind-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #064e3b;
}

.empty-bind-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #475569;
}

.empty-bind-action {
  margin-top: 8rpx;
  background: #166534;
  color: #fff;
  border-radius: 999rpx;
  text-align: center;
  padding: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 打卡汇总 */
.checkin-summary {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  gap: 4rpx;
}
.checkin-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 4rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.1);
}
.checkin-item.good {
  background: rgba(255, 255, 255, 0.25);
}
.checkin-item.warn {
  background: rgba(245, 158, 11, 0.24);
}
.ci-icon {
  font-size: 28rpx;
}
.ci-label {
  font-size: 18rpx;
  opacity: 0.8;
}
.ci-val {
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
}

/* ===== 通用区块 ===== */
.section {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.section-tag {
  background: #eaf6f1;
  color: #245a48;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.section-more {
  font-size: 24rpx;
  color: #338b6d;
}

/* ===== 雷达图 ===== */
.radar-wrapper {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}
.radar-chart {
  width: 220rpx;
  height: 220rpx;
  position: relative;
  flex-shrink: 0;
}
.radar-ring {
  position: absolute;
  border: 1rpx solid #e8e8e8;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.radar-ring-4 {
  width: 220rpx;
  height: 220rpx;
}
.radar-ring-3 {
  width: 165rpx;
  height: 165rpx;
}
.radar-ring-2 {
  width: 110rpx;
  height: 110rpx;
}
.radar-ring-1 {
  width: 55rpx;
  height: 55rpx;
}
.radar-line {
  position: absolute;
  width: 50%;
  height: 1rpx;
  background: #ededed;
  top: 50%;
  left: 50%;
  transform-origin: left center;
}
.radar-line-0 {
  transform: translateY(-50%) rotate(0deg);
}
.radar-line-1 {
  transform: translateY(-50%) rotate(60deg);
}
.radar-line-2 {
  transform: translateY(-50%) rotate(120deg);
}
.radar-line-3 {
  transform: translateY(-50%) rotate(180deg);
}
.radar-line-4 {
  transform: translateY(-50%) rotate(240deg);
}
.radar-line-5 {
  transform: translateY(-50%) rotate(300deg);
}
.radar-area-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 220rpx;
  height: 220rpx;
  z-index: 1;
  pointer-events: none;
}
.radar-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: #338b6d;
  border: 3rpx solid #fff;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 2rpx 6rpx rgba(51, 139, 109, 0.35);
  z-index: 2;
}
.radar-dot-0 {
  background: #166534;
  box-shadow: 0 2rpx 6rpx rgba(22, 101, 52, 0.35);
}
.radar-dot-1 {
  background: #1f7a4a;
  box-shadow: 0 2rpx 6rpx rgba(31, 122, 74, 0.35);
}
.radar-dot-2 {
  background: #2a8f61;
  box-shadow: 0 2rpx 6rpx rgba(42, 143, 97, 0.35);
}
.radar-dot-3 {
  background: #35a478;
  box-shadow: 0 2rpx 6rpx rgba(53, 164, 120, 0.35);
}
.radar-dot-4 {
  background: #46b690;
  box-shadow: 0 2rpx 6rpx rgba(70, 182, 144, 0.35);
}
.radar-dot-5 {
  background: #5cc6a6;
  box-shadow: 0 2rpx 6rpx rgba(92, 198, 166, 0.35);
}
.radar-lbl {
  position: absolute;
  font-size: 18rpx;
  color: #888;
  font-weight: 500;
  white-space: nowrap;
}
.radar-lbl-0,
.lbl-0 {
  top: -32rpx;
  left: 50%;
  transform: translateX(-50%);
}
.radar-lbl-1,
.lbl-1 {
  top: 16rpx;
  right: -8rpx;
}
.radar-lbl-2,
.lbl-2 {
  bottom: 8rpx;
  right: -8rpx;
}
.radar-lbl-3,
.lbl-3 {
  bottom: -32rpx;
  left: 50%;
  transform: translateX(-50%);
}
.radar-lbl-4,
.lbl-4 {
  bottom: 8rpx;
  left: -8rpx;
}
.radar-lbl-5,
.lbl-5 {
  top: 16rpx;
  left: -8rpx;
}

.radar-indicators {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 12rpx;
}
.indicator-item,
.ind-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.indicator-dot,
.ind-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.indicator-label,
.ind-label {
  flex: 1;
  font-size: 22rpx;
  color: #555;
}
.indicator-score,
.ind-score {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  flex-shrink: 0;
}
.indicator-tip,
.ind-note {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.risk-alert {
  display: none;
  align-items: center;
  gap: 12rpx;
  background: #fff3e0;
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1rpx solid #ffe0b2;
}
.risk-alert.show {
  display: flex;
}
.risk-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.risk-text {
  font-size: 24rpx;
  color: #e65100;
  line-height: 1.5;
}

/* ===== 周打卡 ===== */
.week-calendar {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.week-label {
  font-size: 18rpx;
  color: #999;
  text-align: center;
  padding: 8rpx 0;
}
.week-dot-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.week-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 2rpx solid #e0e0e0;
}
.week-dot.done.good {
  background: #eaf6f1;
  border-color: #57a58d;
}
.week-dot.done.warn {
  background: #fff7ed;
  border-color: #f59e0b;
}
.week-emoji {
  font-size: 20rpx;
}
.legend-row {
  display: flex;
  gap: 24rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #f0f0f0;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: #888;
}
.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}
.legend-dot.good {
  background: #57a58d;
}
.legend-dot.warn {
  background: #f59e0b;
}
.legend-dot.none {
  background: #e0e0e0;
}

/* ===== AI建议 ===== */
.ai-advice-section {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  border-left: 6rpx solid #338b6d;
}

.trend-placeholder {
  background: #f8fafc;
  border: 1rpx dashed #cbd5e1;
  border-radius: 14rpx;
  padding: 26rpx 20rpx;
  text-align: center;
}

.trend-placeholder-text {
  font-size: 26rpx;
  color: #475569;
}

.summary-report {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-report-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-risk {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.summary-risk.green {
  background: #eaf6f1;
  color: #245a48;
}

.summary-risk.orange {
  background: #fff7ed;
  color: #f59e0b;
}

.summary-risk.red {
  background: #ffebee;
  color: #f44336;
}

.summary-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.summary-text,
.summary-advice {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
}

.summary-advice {
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 18rpx;
}

.summary-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.summary-metric {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.summary-metric-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #166534;
}

.summary-metric-label {
  font-size: 22rpx;
  color: #64748b;
}
.ai-advice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.ai-advice-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.ai-advice-icon {
  font-size: 32rpx;
}
.ai-advice-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.ai-advice-arrow {
  font-size: 36rpx;
  color: #ccc;
}
.ai-advice-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* ===== 成绩列表 ===== */
.grade-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.grade-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.grade-left {
  display: flex;
  flex-direction: column;
  min-width: 80rpx;
}
.grade-subject {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.grade-date {
  font-size: 20rpx;
  color: #bbb;
}
.grade-bar-wrap {
  flex: 1;
}
.grade-bar-bg {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}
.grade-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.4s;
}
.grade-score {
  font-size: 28rpx;
  font-weight: bold;
  min-width: 80rpx;
  text-align: right;
}

/* ===== 绑定设置弹窗 ===== */
.qr-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 500;
}
.qr-modal.show {
  display: block;
}
.qr-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
}
.qr-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 env(safe-area-inset-bottom);
  max-height: 88vh;
  overflow-y: auto;
}
.qr-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.qr-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.qr-close {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
  padding: 0 8rpx;
}

/* 登录 */
.qr-login {
  padding: 32rpx 36rpx;
}
.qr-login-tip {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}
.qr-phone-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}
.qr-login-btn {
  background: #338b6d;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  text-align: center;
  padding: 24rpx;
  margin-top: 8rpx;
}

/* 加载中 */
.qr-loading {
  padding: 48rpx;
  text-align: center;
}
.qr-loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 二维码内容 */
.qr-content {
  padding: 32rpx 36rpx 48rpx;
}

.bind-id-panel {
  margin: 28rpx 36rpx 0;
  padding: 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
}

.bind-id-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.bind-id-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 18rpx;
}

.bind-id-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.bind-id-input {
  flex: 1;
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  color: #111827;
  letter-spacing: 2rpx;
}

.bind-id-btn {
  flex-shrink: 0;
  background: #166534;
  color: #fff;
  border-radius: 14rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.bind-id-btn.disabled {
  opacity: 0.6;
}

.qr-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}
.qr-image {
  display: block;
  margin: 0 auto 24rpx;
  width: 320rpx;
  height: 320rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
}
.qr-info {
  text-align: center;
  margin-bottom: 24rpx;
}
.qr-info-text {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}
.qr-phone {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
}
.qr-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin-bottom: 24rpx;
}
.qr-children-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
}
.qr-children-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.refresh-btn {
  font-size: 24rpx;
  color: #245a48;
}
.child-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}
.child-item.active {
  background: #f0fdf4;
  margin: 0 -12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 14rpx;
}
.child-item:last-child {
  border-bottom: none;
}
.child-item-avatar {
  width: 64rpx;
  height: 64rpx;
  background: #e8f5e9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #338b6d;
  flex-shrink: 0;
}
.child-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.child-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}
.child-item-grade {
  font-size: 22rpx;
  color: #999;
}
.child-item-status {
  font-size: 22rpx;
  color: #bbb;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}
.child-item-status.online {
  color: #338b6d;
  background: #e8f5e9;
}
.no-children {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #bbb;
}

/* ===== 测评报告 ===== */
.report-card {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #f0f0f0;
}
.report-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.report-type-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.report-type-tag.green {
  background: #eaf6f1;
  color: #245a48;
}
.report-type-tag.orange {
  background: #fff7ed;
  color: #f59e0b;
}
.report-type-tag.red {
  background: #ffebee;
  color: #f44336;
}
.report-date {
  font-size: 20rpx;
  color: #999;
}
.report-summary {
  font-size: 26rpx;
  color: #444;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
}
.report-score-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.report-score-label {
  font-size: 22rpx;
  color: #999;
  flex: 1;
}
.report-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #338b6d;
}
.report-score-max {
  font-size: 22rpx;
  color: #bbb;
}
.report-history {
  display: flex;
  flex-direction: column;
}
.report-history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.report-history-item:last-child {
  border-bottom: none;
}
.report-history-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.report-history-type {
  font-size: 26rpx;
  color: #333;
}
.report-history-date {
  font-size: 20rpx;
  color: #999;
}
.report-history-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.report-history-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.report-arrow {
  font-size: 32rpx;
  color: #ccc;
}
.no-reports {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #bbb;
}

/* ===== 预警横幅 ===== */
.alert-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(244, 67, 54, 0.18);
  border-left: 6rpx solid #f44336;
}
.alert-banner-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.alert-banner-content {
  flex: 1;
}
.alert-banner-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.alert-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.alert-badge {
  background: #f44336;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}
.alert-banner-text {
  display: block;
  font-size: 25rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.alert-banner-time {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}
.alert-banner-arrow {
  font-size: 36rpx;
  color: #ccc;
  flex-shrink: 0;
}
