/* 预警列表页样式 */
.page { background: #f5f5f5; min-height: 100vh; }

/* ===== 顶部栏 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar-left, .top-bar-right { width: 120rpx; }
.back-icon { font-size: 48rpx; color: #333; font-weight: 300; }
.top-bar-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; flex: 1; text-align: center; }
.mark-all-read { font-size: 26rpx; color: #FF9500; text-align: right; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #333; font-weight: 600; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #999; }

/* ===== 预警列表 ===== */
.alert-list { padding: 20rpx 24rpx; }

.alert-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  position: relative;
  transition: transform 0.15s;
}
.alert-item:active { transform: scale(0.98); }
.alert-item.unread { background: #fff; }
.alert-item.read { opacity: 0.6; }

.alert-icon-wrap {
  width: 72rpx; height: 72rpx;
  border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.alert-icon { font-size: 40rpx; }

.alert-content { flex: 1; }

.alert-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.alert-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.alert-tag {
  font-size: 20rpx;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}
.alert-unread-dot {
  width: 12rpx; height: 12rpx;
  background: #f44336;
  border-radius: 50%;
  margin-left: auto;
}

.alert-body {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 10rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.alert-meta {
  display: block;
  font-size: 22rpx;
  color: #bbb;
}

.alert-read-indicator {
  position: absolute;
  top: 28rpx;
  right: 24rpx;
  width: 12rpx; height: 12rpx;
  background: #f44336;
  border-radius: 50%;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 28rpx;
  font-size: 26rpx;
  color: #bbb;
}
.load-more.no-more { color: #ddd; }
