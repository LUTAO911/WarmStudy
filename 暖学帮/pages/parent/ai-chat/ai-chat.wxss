.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ededed;
}

.status-bar {
  background: #ededed;
}

.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #ededed;
  border-bottom: 1rpx solid #d9d9d9;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 40rpx;
  color: #1a1a1a;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

.agent-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 20rpx;
  background: #fff;
  border-radius: 32rpx;
}

.nav-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.agent-meta {
  display: flex;
  flex-direction: column;
}

.agent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.emotion-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.emotion-icon {
  font-size: 20rpx;
}

.emotion-label {
  font-size: 20rpx;
  color: #666;
}

.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.time-divider {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.time-text {
  font-size: 22rpx;
  color: #b3b3b3;
  background: #ededed;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.message-wrapper {
  margin-bottom: 24rpx;
  display: flex;
}

.message-wrapper.ai {
  justify-content: flex-start;
}

.message-wrapper.user {
  justify-content: flex-end;
}

.message-content {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  max-width: 80%;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.bubble-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  position: relative;
  word-break: break-all;
}

.ai-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 1rpx 2rpx rgba(0,0,0,0.05);
}

.user-bubble {
  background: #95ec69;
  border-top-right-radius: 4rpx;
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #1a1a1a;
}

.msg-meta {
  display: flex;
  align-items: center;
}

.emotion-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.loading-message {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.loading-bubble {
  padding: 24rpx 32rpx;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.typing-indicator .dot {
  width: 12rpx;
  height: 12rpx;
  background: #b3b3b3;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-indicator .dot:nth-child(1) { animation-delay: 0s; }
.typing-indicator .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

.stop-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-left: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.stop-icon {
  font-size: 24rpx;
  color: #ff4d4f;
}

.stop-text {
  font-size: 24rpx;
  color: #ff4d4f;
}

.scroll-placeholder {
  flex-shrink: 0;
}

.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f7f7f7;
  border-top: 1rpx solid #d9d9d9;
  padding: 12rpx 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  transition: bottom 0.2s ease;
}

.edit-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: #fff7e6;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.edit-hint {
  font-size: 24rpx;
  color: #fa8c16;
}

.edit-cancel {
  font-size: 24rpx;
  color: #1890ff;
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.input-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.btn-icon {
  font-size: 44rpx;
}

.input-wrapper {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  min-height: 64rpx;
  max-height: 200rpx;
  overflow: hidden;
}

.chat-input {
  width: 100%;
  padding: 14rpx 20rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: #1a1a1a;
  min-height: 64rpx;
  max-height: 200rpx;
}

.input-placeholder {
  color: #b3b3b3;
}

.send-btn {
  width: 100rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.send-btn.active {
  background: #07c160;
}

.send-text {
  font-size: 28rpx;
  color: #b3b3b3;
}

.send-btn.active .send-text {
  color: #fff;
  font-weight: 500;
}

.voice-row {
  justify-content: center;
}

.voice-input-btn {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e5e5e5;
}

.voice-input-btn.recording {
  background: #07c160;
  border-color: #07c160;
}

.voice-btn-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.voice-input-btn.recording .voice-btn-text {
  color: #fff;
}

.context-menu {
  position: fixed;
  z-index: 1000;
  transform: translateX(-50%);
}

.context-menu.show {
  display: block;
}

.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.menu-content {
  display: flex;
  gap: 8rpx;
  background: #4c4c4c;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-label {
  font-size: 20rpx;
  color: #fff;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 500;
  display: none;
}

.modal-overlay.show {
  display: block;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
}

.toolbox-panel, .session-panel, .settings-panel, .avatar-panel, .context-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.toolbox-header, .session-header, .settings-header, .avatar-header, .context-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.toolbox-title, .session-title, .settings-title, .avatar-title, .context-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.toolbox-close, .settings-close, .avatar-close, .context-close {
  font-size: 48rpx;
  color: #b3b3b3;
  line-height: 1;
}

.quick-questions {
  padding: 24rpx 36rpx 0;
}

.quick-title {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.question-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.question-item {
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
}

.question-item text {
  font-size: 24rpx;
  color: #fff;
}

.toolbox-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 32rpx 36rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.tool-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-emoji {
  font-size: 44rpx;
}

.tool-name {
  font-size: 24rpx;
  color: #333;
}

.session-new-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #07c160;
  border-radius: 24rpx;
}

.new-icon {
  font-size: 28rpx;
  color: #fff;
}

.new-text {
  font-size: 24rpx;
  color: #fff;
}

.session-list {
  max-height: 50vh;
  padding: 16rpx 0;
}

.session-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.session-item.active {
  background: #f0faf0;
}

.session-info {
  flex: 1;
  overflow: hidden;
}

.session-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-preview {
  display: block;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  margin-left: 16rpx;
}

.session-time {
  font-size: 22rpx;
  color: #b3b3b3;
}

.session-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.delete-icon {
  font-size: 32rpx;
  color: #999;
}

.empty-session {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.settings-section {
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.avatar-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.current-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-info {
  flex: 1;
}

.avatar-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.avatar-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.picker-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.emotion-slider {
  padding: 0 8rpx;
}

.slider {
  width: 100%;
}

.emotion-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.label-item {
  font-size: 22rpx;
  color: #999;
}

.current-emotion {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

.emotion-display {
  font-size: 28rpx;
  font-weight: 500;
}

.about-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.about-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.about-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.avatar-list {
  padding: 16rpx 36rpx 32rpx;
}

.avatar-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.avatar-option:last-child {
  margin-bottom: 0;
}

.option-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.option-info {
  flex: 1;
}

.option-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  border-radius: 50%;
}

.check-icon {
  font-size: 28rpx;
  color: #fff;
}

.context-scroll {
  max-height: 50vh;
  padding: 24rpx 36rpx;
}

.context-summary {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f0faf0;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #666;
}

.summary-count {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 600;
}

.context-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.context-item {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.context-role {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.context-role.ai {
  background: #e6f7ff;
}

.context-role.user {
  background: #f6ffed;
}

.role-text {
  font-size: 22rpx;
  font-weight: 500;
}

.context-role.ai .role-text {
  color: #1890ff;
}

.context-role.user .role-text {
  color: #52c41a;
}

.context-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}
