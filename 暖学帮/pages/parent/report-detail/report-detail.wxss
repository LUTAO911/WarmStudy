/* report-detail.wxss */
.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== 报告头部 ===== */
.report-header {
  background: linear-gradient(135deg, #FF9500 0%, #ffb340 100%);
  padding: 48rpx 32rpx 36rpx;
  color: #fff;
  border-radius: 0 0 32rpx 32rpx;
}
.report-type-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.report-type {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}
.report-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.report-score-circle {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.score-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
}
.score-inner {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.score-num {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
}
.score-denom {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
}
.score-label-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.level-badge {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.25);
  border: 2rpx solid rgba(255,255,255,0.5);
  color: #fff;
  font-weight: 500;
  align-self: flex-start;
}
.level-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== 通用区块 ===== */
.section {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
}
.section-label.ai-label { color: #2196f3; }
.section-label.parent-label { color: #FF9500; }

/* ===== 报告摘要 ===== */
.report-summary {
  font-size: 28rpx;
  color: #444;
  line-height: 1.7;
}

/* ===== 关键发现 ===== */
.finding-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.finding-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.finding-num {
  width: 40rpx;
  height: 40rpx;
  background: #fff3e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  color: #FF9500;
  flex-shrink: 0;
}
.finding-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* ===== 维度分析 ===== */
.dim-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.dim-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.dim-name { font-size: 28rpx; color: #333; font-weight: 500; }
.dim-score { font-size: 28rpx; font-weight: bold; }
.dim-score.normal { color: #00C853; }
.dim-score.mild { color: #4caf50; }
.dim-score.moderate { color: #ff9800; }
.dim-score.concerning { color: #f44336; }
.dim-score.severe { color: #c62828; }
.dim-bar-bg {
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}
.dim-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.4s;
}
.dim-bar-fill.normal { background: #00C853; }
.dim-bar-fill.mild { background: #4caf50; }
.dim-bar-fill.moderate { background: #ff9800; }
.dim-bar-fill.concerning { background: #f44336; }
.dim-bar-fill.severe { background: #c62828; }
.dim-desc { font-size: 22rpx; color: #999; }

/* ===== AI建议卡片 ===== */
.advice-card {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 4rpx solid #2196f3;
}
.advice-card.parent-card {
  border-left-color: #FF9500;
}
.advice-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  display: block;
}

/* ===== 风险提示 ===== */
.risk-card {
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.risk-card.concerning {
  background: #fff3e0;
  border: 1rpx solid #ffe0b2;
}
.risk-card.severe {
  background: #ffebee;
  border: 1rpx solid #ffcdd2;
}
.risk-icon { font-size: 40rpx; flex-shrink: 0; }
.risk-content { flex: 1; }
.risk-title { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 6rpx; }
.risk-card.concerning .risk-title { color: #e65100; }
.risk-card.severe .risk-title { color: #c62828; }
.risk-desc { font-size: 26rpx; line-height: 1.6; display: block; }
.risk-card.concerning .risk-desc { color: #bf360c; }
.risk-card.severe .risk-desc { color: #b71c1c; }
