<view class="page">
  <!-- 头部 -->
  <view class="page-header">
    <view class="header-top">
      <view class="header-child-info">
        <view class="child-avatar-wrap">
          <view class="child-avatar">李</view>
          <view class="online-dot"></view>
        </view>
        <view class="child-detail">
          <text class="child-name">{{childInfo.name}} · {{childInfo.grade}}{{childInfo.class}}</text>
          <text class="child-meta">学号：{{childInfo.studentId}}</text>
        </view>
      </view>
      <view class="header-right">
        <view class="header-date">{{today}}</view>
        <!-- 绑定设置按钮 -->
        <view class="bind-btn" bindtap="onShowBindQR">
          <text>📱 绑定设置</text>
        </view>
      </view>
    </view>
    <!-- 打卡汇总 -->
    <view class="checkin-summary">
      <view class="checkin-item {{checkin.emotion >= 3 ? 'good' : 'warn'}}">
        <text class="ci-icon">😊</text><text class="ci-label">情绪</text><text class="ci-val">{{checkin.emotion}}/5</text>
      </view>
      <view class="checkin-item {{checkin.study >= 3 ? 'good' : 'warn'}}">
        <text class="ci-icon">📚</text><text class="ci-label">学习</text><text class="ci-val">{{checkin.study}}/5</text>
      </view>
      <view class="checkin-item {{checkin.sleep >= 3 ? 'good' : 'warn'}}">
        <text class="ci-icon">😴</text><text class="ci-label">睡眠</text><text class="ci-val">{{checkin.sleep}}/5</text>
      </view>
      <view class="checkin-item {{checkin.social >= 3 ? 'good' : 'warn'}}">
        <text class="ci-icon">👫</text><text class="ci-label">社交</text><text class="ci-val">{{checkin.social}}/5</text>
      </view>
    </view>
  </view>

  <!-- 预警通知卡片 -->
  <view class="alert-banner {{latestUnreadAlert ? 'has-alert' : ''}}" bindtap="goToAlerts" wx:if="{{latestUnreadAlert}}">
    <view class="alert-banner-icon" style="background:{{alertTypeMap[latestUnreadAlert.alert_type].color}}">
      {{alertTypeMap[latestUnreadAlert.alert_type].icon}}
    </view>
    <view class="alert-banner-content">
      <view class="alert-banner-header">
        <text class="alert-banner-title">{{latestUnreadAlert.title}}</text>
        <view class="alert-badge" wx:if="{{unreadAlertCount > 1}}">{{unreadAlertCount}} 条未读</view>
      </view>
      <text class="alert-banner-text">{{latestUnreadAlert.content}}</text>
      <text class="alert-banner-time">{{latestUnreadAlert.created_at}}</text>
    </view>
    <text class="alert-banner-arrow">›</text>
  </view>

  <!-- 心理画像 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近心理画像</text>
      <text class="section-tag">参考值</text>
    </view>
    <view class="radar-wrapper">
      <view class="radar-chart">
        <view class="radar-ring radar-ring-4"></view>
        <view class="radar-ring radar-ring-3"></view>
        <view class="radar-ring radar-ring-2"></view>
        <view class="radar-ring radar-ring-1"></view>
        <view class="radar-line radar-line-0"></view>
        <view class="radar-line radar-line-1"></view>
        <view class="radar-line radar-line-2"></view>
        <view class="radar-line radar-line-3"></view>
        <view class="radar-line radar-line-4"></view>
        <view class="radar-line radar-line-5"></view>
        <view class="radar-dot" style="{{dot0Style}}"></view>
        <view class="radar-dot" style="{{dot1Style}}"></view>
        <view class="radar-dot" style="{{dot2Style}}"></view>
        <view class="radar-dot" style="{{dot3Style}}"></view>
        <view class="radar-dot" style="{{dot4Style}}"></view>
        <view class="radar-dot" style="{{dot5Style}}"></view>
        <text class="radar-lbl lbl-0">学习焦虑</text>
        <text class="radar-lbl lbl-1">对人焦虑</text>
        <text class="radar-lbl lbl-2">孤独倾向</text>
        <text class="radar-lbl lbl-3">自责倾向</text>
        <text class="radar-lbl lbl-4">过敏倾向</text>
        <text class="radar-lbl lbl-5">身体症状</text>
      </view>
      <view class="radar-indicators">
        <view class="ind-item"><view class="ind-dot" style="background:#f44336"></view><text class="ind-label">学习焦虑</text><text class="ind-score">{{radarScores[0]}}</text></view>
        <view class="ind-item"><view class="ind-dot" style="background:#e91e63"></view><text class="ind-label">对人焦虑</text><text class="ind-score">{{radarScores[1]}}</text></view>
        <view class="ind-item"><view class="ind-dot" style="background:#9c27b0"></view><text class="ind-label">孤独倾向</text><text class="ind-score">{{radarScores[2]}}</text></view>
        <view class="ind-item"><view class="ind-dot" style="background:#ff9800"></view><text class="ind-label">自责倾向</text><text class="ind-score">{{radarScores[3]}}</text></view>
        <view class="ind-item"><view class="ind-dot" style="background:#2196f3"></view><text class="ind-label">过敏倾向</text><text class="ind-score">{{radarScores[4]}}</text></view>
        <view class="ind-item"><view class="ind-dot" style="background:#00bcd4"></view><text class="ind-label">身体症状</text><text class="ind-score">{{radarScores[5]}}</text></view>
        <text class="ind-note">原始分，越低越健康</text>
      </view>
    </view>
    <view class="risk-alert {{riskLevel >= 3 ? 'show' : ''}}">
      <text class="risk-icon">⚠️</text>
      <text class="risk-text">检测到 {{riskLevel}} 项指标偏高，建议与孩子多沟通</text>
    </view>
  </view>

  <!-- 本周打卡 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">本周打卡</text>
      <text class="section-more">历史记录 ›</text>
    </view>
    <view class="week-calendar">
      <view class="week-label">一</view><view class="week-label">二</view><view class="week-label">三</view>
      <view class="week-label">四</view><view class="week-label">五</view><view class="week-label">六</view><view class="week-label">日</view>
      <view class="week-dot-item {{item.emotion >= 3 ? 'good' : 'warn'}}" wx:for="{{weekCheckins}}" wx:key="day">
        <view class="week-dot {{item.done ? 'done' : ''}} {{item.emotion >= 3 ? 'good' : 'warn'}}"></view>
        <text class="week-emoji">{{item.done ? (item.emotion >= 3 ? '😊' : '😔') : '·'}}</text>
      </view>
    </view>
    <view class="legend-row">
      <view class="legend-item"><view class="legend-dot good"></view><text>状态良好</text></view>
      <view class="legend-item"><view class="legend-dot warn"></view><text>需要关注</text></view>
      <view class="legend-item"><view class="legend-dot none"></view><text>未打卡</text></view>
    </view>
  </view>

  <!-- AI建议 -->
  <view class="section ai-advice-section" bindtap="goToAI">
    <view class="ai-advice-header">
      <view class="ai-advice-title-row">
        <text class="ai-advice-icon">💡</text>
        <text class="ai-advice-title">AI今日建议</text>
      </view>
      <text class="ai-advice-arrow">›</text>
    </view>
    <text class="ai-advice-text">{{aiAdvice}}</text>
  </view>

  <!-- 成绩趋势 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">成绩趋势</text>
      <text class="section-more">历史 ›</text>
    </view>
    <view class="grade-list">
      <view class="grade-item" wx:for="{{recentGrades}}" wx:key="subject">
        <view class="grade-left">
          <text class="grade-subject">{{item.subject}}</text>
          <text class="grade-date">{{item.examDate}}</text>
        </view>
        <view class="grade-bar-wrap">
          <view class="grade-bar-bg">
            <view class="grade-bar-fill" style="width:{{item.score}}%;background:{{item.score >= 90 ? '#00C853' : item.score >= 75 ? '#FF9500' : '#ff3b30'}}"></view>
          </view>
        </view>
        <text class="grade-score" style="color:{{item.score >= 90 ? '#00C853' : item.score >= 75 ? '#FF9500' : '#ff3b30'}}">{{item.score}}分</text>
      </view>
    </view>
  </view>

  <!-- 测评报告 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📋 测评报告</text>
      <text class="section-more" bindtap="onViewAllReports">全部报告 ›</text>
    </view>
    <view wx:if="{{psychReports.length > 0}}">
      <!-- 最新报告卡片 -->
      <view class="report-card" bindtap="onViewReportDetail" data-id="{{psychReports[0].id}}">
        <view class="report-card-header">
          <view class="report-type-tag {{psychReports[0].level === 'severe' ? 'red' : psychReports[0].level === 'concerning' ? 'orange' : 'green'}}">
            {{reportLevelLabel[psychReports[0].level] || '正常'}}
          </view>
          <text class="report-date">{{psychReports[0].date}}</text>
        </view>
        <text class="report-summary">{{psychReports[0].summary || psychReports[0].advice || '暂无摘要'}}</text>
        <view class="report-score-row">
          <text class="report-score-label">综合得分</text>
          <text class="report-score">{{psychReports[0].normalized}}</text>
          <text class="report-score-max">/100</text>
        </view>
      </view>
      <!-- 历史报告列表 -->
      <view class="report-history">
        <view class="report-history-item" wx:for="{{psychReports}}" wx:for-item="rp" wx:key="id" wx:if="{{index > 0}}" bindtap="onViewReportDetail" data-id="{{rp.id}}">
          <view class="report-history-left">
            <text class="report-history-type">{{reportTypeLabel[rp.scale_id] || rp.scale_id}}</text>
            <text class="report-history-date">{{rp.date}}</text>
          </view>
          <view class="report-history-right">
            <view class="report-history-tag {{rp.level === 'severe' ? 'red' : rp.level === 'concerning' ? 'orange' : 'green'}}">
              {{reportLevelLabel[rp.level] || '正常'}}
            </view>
            <text class="report-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{psychReports.length === 0 && !psychReportsLoading}}" class="no-reports">
      <text>暂无测评报告</text>
    </view>
    <view wx:if="{{psychReportsLoading}}" class="no-reports">
      <text>加载中...</text>
    </view>
  </view>

  <view style="height:40rpx"></view>

  <!-- 绑定设置弹窗 -->
  <view class="qr-modal {{showQR ? 'show' : ''}}" wx:if="{{showQR}}">
    <view class="qr-mask" bindtap="onCloseQR"></view>
    <view class="qr-sheet">
      <view class="qr-header">
        <text class="qr-title">📱 绑定设置</text>
        <text class="qr-close" bindtap="onCloseQR">×</text>
      </view>

      <!-- 登录区 -->
      <view wx:if="{{!isLoggedIn}}" class="qr-login">
        <text class="qr-login-tip">请先登录家长端</text>
        <input class="qr-phone-input" type="number" maxlength="11" placeholder="输入手机号登录" value="{{loginPhone}}" bindinput="onPhoneInput"/>
        <view class="qr-login-btn" bindtap="onLogin">登录 / 注册</view>
      </view>

      <!-- 已登录：显示二维码 -->
      <view wx:if="{{isLoggedIn && !qrData}}" class="qr-loading">
        <text class="qr-loading-text">正在生成二维码...</text>
      </view>

      <view wx:if="{{isLoggedIn && qrData}}" class="qr-content">
        <text class="qr-desc">让孩子扫下方二维码绑定</text>
        <image class="qr-image" src="{{qrData.qrImageUrl}}" mode="aspectFit" show-menu-by-longpress/>
        <view class="qr-info">
          <text class="qr-info-text">或告诉孩子您的手机号</text>
          <text class="qr-phone">{{parentPhone}}</text>
        </view>
        <view class="qr-divider"></view>
        <view class="qr-children">
          <view class="qr-children-header">
            <text class="qr-children-title">已绑定的孩子</text>
            <view class="refresh-btn" bindtap="onRefreshChildren">↻ 刷新</view>
          </view>
          <view class="child-item" wx:for="{{boundChildren}}" wx:key="id">
            <view class="child-item-avatar">{{item.name[0]}}</view>
            <view class="child-item-info">
              <text class="child-item-name">{{item.name}}</text>
              <text class="child-item-grade">{{item.grade}}</text>
            </view>
            <text class="child-item-status {{item.active ? 'online' : ''}}">{{item.active ? '在线' : '未上线'}}</text>
          </view>
          <view wx:if="{{boundChildren.length === 0}}" class="no-children">
            <text>暂无绑定孩子，扫码后可查看</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <tab-bar />
</view>
