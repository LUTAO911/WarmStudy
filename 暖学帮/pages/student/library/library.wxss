/* library.wxss - 心理成长中心 */
.page { background: #f8f9fc; min-height: 100vh; padding-bottom: 120rpx; }

/* ===== 心理头部 ===== */
.psych-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 100rpx;
  color: #fff;
}
.psych-welcome {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}
.welcome-text { font-size: 36rpx; font-weight: bold; color: #fff; }
.date-text { font-size: 24rpx; opacity: 0.8; }

/* 今日心情卡片 */
.today-mood-card {
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
}
.mood-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.mood-icon { font-size: 64rpx; }
.mood-info { flex: 1; }
.mood-label { font-size: 32rpx; font-weight: bold; color: #333; display: block; }
.mood-score { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.mood-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 30rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
}
.mood-track {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
}
.mood-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

/* ===== 功能网格 ===== */
.section {
  margin: -60rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title { font-size: 32rpx; font-weight: bold; color: #1a1a1a; }
.section-more { font-size: 26rpx; color: #667eea; }

.psych-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}
.psych-card {
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
}
.psych-card:active {
  transform: scale(0.96);
}
.card-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.card-title { font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.card-desc { font-size: 20rpx; color: #666; line-height: 1.4; }
.card-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(255,255,255,0.9);
  color: #667eea;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* ===== 本周趋势 ===== */
.week-trend-card {
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
  border-radius: 20rpx;
  padding: 24rpx;
}
.trend-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.trend-score {
  display: flex;
  align-items: baseline;
  margin-right: 20rpx;
}
.score-num { font-size: 56rpx; font-weight: bold; color: #667eea; }
.score-unit { font-size: 24rpx; color: #999; margin-left: 4rpx; }
.trend-info { flex: 1; }
.trend-label { font-size: 24rpx; color: #666; display: block; }
.trend-badge {
  display: inline-block;
  margin-top: 6rpx;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.trend-badge.up { background: #e8f5e9; color: #4caf50; }
.trend-badge.down { background: #ffebee; color: #f44336; }
.trend-badge.stable { background: #e3f2fd; color: #2196f3; }

.week-chart {
  width: 100%;
  height: 200rpx;
  margin: 16rpx 0;
}

.trend-suggestions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ddd;
}
.suggestions-title { font-size: 26rpx; font-weight: bold; color: #333; display: block; margin-bottom: 12rpx; }
.suggestion-item { font-size: 24rpx; color: #666; line-height: 1.8; }

/* ===== 心理知识列表 ===== */
.knowledge-list { display: flex; flex-direction: column; gap: 20rpx; }
.knowledge-item {
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 24rpx;
  transition: background 0.2s;
}
.knowledge-item:active { background: #f0f2f5; }
.knowledge-content { display: flex; flex-direction: column; gap: 8rpx; }
.knowledge-header { display: flex; align-items: center; gap: 12rpx; }
.knowledge-category {
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102,126,234,0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.knowledge-new {
  font-size: 20rpx;
  color: #fff;
  background: #f44336;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}
.knowledge-title { font-size: 30rpx; font-weight: bold; color: #1a1a1a; line-height: 1.4; }
.knowledge-summary { font-size: 24rpx; color: #666; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.knowledge-time { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* ===== 紧急求助 ===== */
.crisis-banner {
  margin: 20rpx 24rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #fff;
}
.crisis-icon { font-size: 48rpx; flex-shrink: 0; }
.crisis-info { flex: 1; }
.crisis-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 4rpx; }
.crisis-desc { font-size: 22rpx; opacity: 0.9; line-height: 1.4; }
.crisis-arrow { font-size: 40rpx; opacity: 0.7; flex-shrink: 0; }

/* ===== 模态框 ===== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.modal.show { opacity: 1; pointer-events: all; }
.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}
.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.modal.show .modal-content { transform: translateY(0); }

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.modal-title { font-size: 34rpx; font-weight: bold; color: #1a1a1a; }
.modal-close { font-size: 48rpx; color: #999; line-height: 1; }

/* 情绪选择器 */
.mood-options {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}
.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: background 0.2s;
}
.mood-option:active { background: #f5f5f5; }
.mood-emoji { font-size: 64rpx; }
.mood-text { font-size: 24rpx; color: #666; }

.mood-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

/* 知识详情 */
.knowledge-detail { margin-bottom: 32rpx; }
.detail-meta { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.detail-category { font-size: 24rpx; color: #667eea; }
.detail-time { font-size: 24rpx; color: #999; }
.detail-summary { font-size: 28rpx; color: #666; line-height: 1.6; }

.modal-actions { padding-top: 20rpx; }
.action-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}
.action-btn::after { border: none; }
