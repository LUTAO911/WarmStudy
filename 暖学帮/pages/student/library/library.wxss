/* library.wxss - 随心学 */
.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 40rpx; }

/* ===== 用户信息头部 ===== */
.user-header {
  background: linear-gradient(135deg, #00C853 0%, #69f0ae 100%);
  padding: 32rpx 32rpx 28rpx;
  color: #fff;
  border-radius: 0 0 24rpx 24rpx;
}
.user-info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
  background: #fff;
}
.user-detail { flex: 1; }
.user-name { font-size: 32rpx; font-weight: bold; display: block; color: #fff; }
.user-class { font-size: 22rpx; opacity: 0.85; display: block; margin-top: 4rpx; }

.bind-parent-btn {
  background: rgba(255,255,255,0.25);
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: 30rpx;
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}
.bind-parent-btn.bound {
  background: rgba(255,255,255,0.35);
  border-color: #fff;
}


/* 心理状态条 */
.psych-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  background: rgba(0,0,0,0.1);
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
}
.psych-label { font-size: 24rpx; opacity: 0.9; flex-shrink: 0; }
.psych-track {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 6rpx;
  overflow: hidden;
}
.psych-fill {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.4s;
}
.psych-score { font-size: 24rpx; font-weight: bold; flex-shrink: 0; }

/* ===== 功能入口网格 ===== */
.feature-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx 24rpx 0;
}
.feature-card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.feature-card-wide { width: 100%; display: flex; align-items: center; gap: 24rpx; padding: 24rpx; }
.feature-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}
.feature-card-wide .feature-icon { margin-bottom: 0; }
.feature-text-group { flex: 1; }
.feature-title { font-size: 30rpx; font-weight: bold; color: #1a1a1a; display: block; margin-bottom: 6rpx; text-align: center; }
.feature-desc { font-size: 22rpx; color: #999; display: block; text-align: center; }
.feature-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #ff9500;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== 今日待办紧贴头部 ===== */
.section-todo {
  margin-top: 0;
  border-radius: 0;
}

/* ===== 通用区块 ===== */
.section {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title { font-size: 30rpx; font-weight: bold; color: #1a1a1a; }
.add-btn { font-size: 26rpx; color: #00C853; }

/* ===== 筛选 ===== */
.filter-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.filter-pick {
  flex: 1;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
}
.confirm-btn {
  background: #00C853;
  color: #fff;
  border-radius: 10rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

/* ===== 搜索结果 ===== */
.book-result { margin-top: 20rpx; }
.result-tip { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.book-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.book-info { display: flex; flex-direction: column; gap: 4rpx; }
.book-sub { font-size: 28rpx; color: #333; font-weight: 500; }
.book-grade { font-size: 22rpx; color: #999; }
.book-name { font-size: 28rpx; color: #333; }
.book-add-btn {
  font-size: 24rpx;
  color: #00C853;
  border: 1rpx solid #00C853;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}
.book-add-btn.added { color: #999; border-color: #ddd; }

/* ===== 我的教材列表 ===== */
.my-books-list { margin-top: 8rpx; }
.grade-query-btn {
  font-size: 24rpx;
  color: #ff9500;
  background: #fff3e0;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

/* ===== 分组管理 ===== */
.group-item { margin-bottom: 12rpx; }
.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.group-name { font-size: 28rpx; font-weight: bold; color: #1a1a1a; }
.group-count { font-size: 24rpx; color: #999; }
.group-books .book-row { padding-left: 24rpx; }

/* ===== 待办事项 ===== */
.todo-list { display: flex; flex-direction: column; gap: 16rpx; }
.todo-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.todo-item.done .todo-text { text-decoration: line-through; color: #ccc; }
.todo-check { flex-shrink: 0; }
.check-icon { font-size: 36rpx; }
.check-icon.green { color: #00C853; }
.check-icon.red { color: #ff3b30; }
.todo-text { flex: 1; font-size: 28rpx; color: #333; }
.todo-source {
  font-size: 20rpx; padding: 4rpx 12rpx;
  border-radius: 8rpx; flex-shrink: 0;
}
.todo-source.psych { background: #e8f5e9; color: #00C853; }
.todo-source.auto { background: #fff3e0; color: #ff9500; }
.todo-source.manual { background: #e3f2fd; color: #2196f3; }
.todo-del { font-size: 32rpx; color: #ccc; flex-shrink: 0; padding-left: 12rpx; }

.empty-tip { font-size: 26rpx; color: #bbb; text-align: center; padding: 24rpx 0; }
